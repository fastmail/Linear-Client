#!perl
use v5.34.0;
use warnings;

use experimental 'signatures';

use Future::AsyncAwait;

use lib 'lib';

use Linear::Client;

binmode STDOUT, ":utf8";

my $auth = $ENV{LINEAR_AUTH} // die "no LINEAR_AUTH env var set!\n";

my $client = Linear::Client->new({
  auth_token => $auth,
});

async sub get_user {
  my ($key) = @_;
  my $user = await $client->lookup_user($key);

  if ($user) {
    say "$user->{id} / $user->{displayName} / $user->{name}";
  } else {
    say "No such user.";
  }
}

async sub list_users {
  my $users = await $client->users;

  for my $user_key (sort keys %$users) {
    printf "%-12s - %s - %s\n",
      $user_key,
      $users->{$user_key}{id},
      $users->{$user_key}{name};
  }

  return;
}

if (@ARGV == 1) {
  await get_user($ARGV[0]);
} elsif (@ARGV) {
  die "too many arguments!\n";
} else {
  await list_users;
}
