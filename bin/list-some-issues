#!perl
use v5.34.0;
use warnings;

use experimental 'signatures';

use Future::AsyncAwait;

use lib 'lib';

use Linear::Client;

binmode STDOUT, ":utf8";

my $auth = $ENV{LINEAR_AUTH} // die "no LINEAR_AUTH env var set!\n";

my $client = Linear::Client->new({
  auth_token => $auth,
});

async sub do_list {
  my $user_id = await $client->get_authenticated_userId;
  my $query_result = await $client->search_issues({
    assignee => $user_id,
  });

  for my $node ($query_result->{data}{issues}{nodes}->@*) {
    printf "%10s - %s\n", $node->{identifier}, $node->{title};
  }

  return;
}

await do_list;
