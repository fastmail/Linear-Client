#!perl
use v5.34.0;
use warnings;

use lib 'lib';

use Linear::Client;

binmode STDOUT, ":utf8";

$Linear::Client::AUTH = $ENV{LINEAR_AUTH} // die "no LINEAR_AUTH env var set!\n";

# Linear::Client::create_issue("++ eat more scrapple");
my $authenticated_user = Linear::Client::get_authenticated_userId();

my $res = Linear::Client::do_query(qq[
query {
  issues(filter: { assignee: { id: { eq: "$authenticated_user" } } }) {
    nodes {
      identifier
      title
    }
  }
}
]);

for my $node ($res->{data}{issues}{nodes}->@*) {
  printf "%10s - %s\n", $node->{identifier}, $node->{title};
}
